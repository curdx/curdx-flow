{
  "name": "@curdx/flow",
  "version": "6.0.4",
  "description": "Interactive installer for Claude Code plugins and MCP servers",
  "type": "module",
  "bin": "./dist/index.mjs",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "check-versions": "node scripts/check-versions.mjs",
    "bump-version": "node scripts/bump-version.mjs",
    "prepublishOnly": "node scripts/check-versions.mjs && npm run typecheck && npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "installer",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/curdx/curdx-flow.git"
  },
  "bugs": {
    "url": "https://github.com/curdx/curdx-flow/issues"
  },
  "homepage": "https://github.com/curdx/curdx-flow#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "citty": "^0.1.6",
    "picocolors": "^1.1.0",
    "tinyexec": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
